{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["core/**/*", "intake/**/*", "renderers/**/*", "adapters/**/*", "manifests/**/*", "app/**/*", "index.ts"],
  "exclude": ["node_modules", "dist", "tests", "examples"]
}
