{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["core/**/*", "renderers/**/*", "adapters/**/*", "app/**/*", "index.ts"],
  "exclude": ["node_modules", "dist", "tests", "examples"]
}
